{
	"version": 6,
	"configurePresets": [
		{
			"name": "samd21g18a-debug",
			"displayName": "SAMD21G18A Debug Bootloader",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/samd21g18a-debug",
			"toolchainFile": "${sourceDir}/cmake/toolchain_arm_none_eabi.cmake",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "samd21g18a-release",
			"displayName": "SAMD21G18A Release Bootloader",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/samd21g18a-release",
			"toolchainFile": "${sourceDir}/cmake/toolchain_arm_none_eabi.cmake",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	],
	"buildPresets": [
		{
			"name": "samd21g18a-debug",
			"configurePreset": "samd21g18a-debug"
		},
		{
			"name": "samd21g18a-release",
			"configurePreset": "samd21g18a-release"
		}
	]
}
